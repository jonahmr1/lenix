{
  "name": "@lenix/lenix",
  "version": "1.7.4111",
  "license": "MIT",
  "exports": {
    ".": "./modules/index.ts",
    "./beta": "./tsconfig.beta.json"
  },
  "publish": {
    "include": ["modules/**", "tsconfig.beta.json", "LICENSE", "README.md"]
  },
  "tasks": {
    "check": "deno check modules/index.ts"
  },
  "imports": {
    "@types/react": "npm:@types/react@^19.2.17",
    "react": "npm:react@^19.2.7",
    "tailwind-merge": "npm:tailwind-merge@^3.6.0"
  },
  "fmt": {
    "useTabs": true,
    "indentWidth": 2,
    "semiColons": false,
    "singleQuote": true,
    "operatorPosition": "nextLine",
    "lineWidth": 100,
		"typeLiteral.separatorKind": "comma",
		"trailingCommas": "never",
    "include": ["modules"]
  },
  "lint": {
		"include": ["modules"],
    "rules": {
      "tags": ["recommended", "fresh", "workspace", "jsr"],
			"exclude": ["no-sloppy-imports"],
      "include": [
        "camelcase",
        "default-param-last",
        "eqeqeq",
        "explicit-function-return-type",
        "explicit-module-boundary-types",
        "no-await-in-loop",
        "no-boolean-literal-for-arguments",
        "no-console",
        "no-eval",
        "no-external-import",
        "no-implicit-declare-namespace-export",
        "no-inferrable-types",
        "no-non-null-asserted-optional-chain",
        "no-non-null-assertion",
        "no-self-compare",
        "no-sparse-arrays",
        "no-sync-fn-in-async-fn",
        "no-throw-literal",
        "no-top-level-await",
        "no-undef",
        "no-useless-rename",
        "prefer-ascii",
        "single-var-declarator",
        "triple-slash-reference"
      ]
    }
  }
}
