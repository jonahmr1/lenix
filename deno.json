{
	"name": "@lenix/lenix",
	"version": "1.8.9",
	"license": "MIT",
	"exports": "./modules/index.ts",
	"publish": {
		"include": [
			"modules/**",
			"LICENSE",
			"README.md"
		]
	},
	"tasks": {
		"check": "deno check modules/index.ts",
		"pre": "deno publish --dry-run"
	},
	"imports": {
		"@citizenfx/client": "npm:@citizenfx/client@2.0.32698-1",
		"@citizenfx/server": "npm:@citizenfx/server@2.0.32561-1"
	},
	"compilerOptions": {
		"types": ["@citizenfx/server", "@citizenfx/client"]
	},
	"fmt": {
		"useTabs": true,
		"indentWidth": 2,
		"semiColons": false,
		"singleQuote": true,
		"operatorPosition": "nextLine",
		"lineWidth": 100,
		"typeLiteral.separatorKind": "comma",
		"trailingCommas": "never",
		"include": [
			"modules"
		]
	},
	"lint": {
		"include": [
			"modules/**"
		],
		"rules": {
			"tags": [
				"recommended",
				"fresh",
				"workspace",
				"jsr"
			],
			"exclude": [
				"no-sloppy-imports"
			],
			"include": [
				"camelcase",
				"default-param-last",
				"eqeqeq",
				"explicit-function-return-type",
				"explicit-module-boundary-types",
				"no-await-in-loop",
				"no-boolean-literal-for-arguments",
				"no-console",
				"no-eval",
				"no-external-import",
				"no-implicit-declare-namespace-export",
				"no-inferrable-types",
				"no-non-null-asserted-optional-chain",
				"no-non-null-assertion",
				"no-self-compare",
				"no-sparse-arrays",
				"no-sync-fn-in-async-fn",
				"no-throw-literal",
				"no-top-level-await",
				"no-undef",
				"no-useless-rename",
				"prefer-ascii",
				"single-var-declarator",
				"triple-slash-reference"
			]
		}
	}
}
