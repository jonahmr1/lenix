{
	"extends": "./tsconfig.beta",
	"compilerOptions": {
		"target": "esnext",
		"module": "esnext",
		"strict": true,
		"declaration": true,
		"moduleResolution": "bundler",
		"allowImportingTsExtensions": true,
		"noEmit": true,
		"paths": {
			"~/*": ["./*"]
		}
	},
	"include": ["*.ts", "modules/**/*"]
}
